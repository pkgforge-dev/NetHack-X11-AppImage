diff --git a/sys/unix/unixmain.c b/sys/unix/unixmain.c
--- a/sys/unix/unixmain.c
+++ b/sys/unix/unixmain.c
@@ -228,13 +228,38 @@ chdirx(const char *dir, boolean wr)
         */
 #ifdef VAR_PLAYGROUND
-        int len = strlen(VAR_PLAYGROUND);
-
-        /* FIXME: this allocation never gets freed.
+        const char *home;
+        int len;
+
+        /*
+         * If VAR_PLAYGROUND is a relative path (starts with '.'),
+         * resolve it under $HOME so that writable files go to a
+         * writable location when running from a read-only mount.
          */
-        gf.fqn_prefix[SCOREPREFIX] = (char *) alloc(len + 2);
