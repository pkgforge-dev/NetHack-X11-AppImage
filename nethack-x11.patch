+            gf.fqn_prefix[SCOREPREFIX] = (char *) alloc(len + 2);
+            Strcpy(gf.fqn_prefix[SCOREPREFIX], home);
+            Strcat(gf.fqn_prefix[SCOREPREFIX], "/");
+            Strcat(gf.fqn_prefix[SCOREPREFIX], VAR_PLAYGROUND);
+            len = strlen(gf.fqn_prefix[SCOREPREFIX]);
+            (void) mkdir(gf.fqn_prefix[SCOREPREFIX], 0755);
+        } else {
+            len = strlen(VAR_PLAYGROUND);
+            /* FIXME: this allocation never gets freed. */
+            gf.fqn_prefix[SCOREPREFIX] = (char *) alloc(len + 2);
+            Strcpy(gf.fqn_prefix[SCOREPREFIX], VAR_PLAYGROUND);
+        }
        if (gf.fqn_prefix[SCOREPREFIX][len - 1] != '/') {
